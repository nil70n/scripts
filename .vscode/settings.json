{
  // AutoHotkey v2 LSP (thqby.vscode-autohotkey2-lsp)
  "AutoHotkey2.InterpreterPath": "${env:USERPROFILE}\\AppData\\Local\\Programs\\AutoHotkey\\v2\\AutoHotkey64.exe",
  "AutoHotkey2.ActionWhenV1IsDetected": "SwitchToV1",
  "AutoHotkey2.GeneralConfiguration.ShowOutput": "always",
  "AutoHotkey2.Warn": {
    "VarUnset": true,
    "LocalSameAsGlobal": true,
    "Unreachable": true
  },
  "AutoHotkey2.Files.MaxScanDepth": 2,
  "AutoHotkey2.FormatOptions": {
    "indent_string": "    "
  },
  "[ahk2]": {
    "editor.defaultFormatter": "thqby.vscode-autohotkey2-lsp",
    "editor.formatOnSave": false,
    "editor.tabSize": 4,
    "editor.insertSpaces": true
  },
  "files.associations": {
    "*.ahk": "ahk2",
    "*.ah2": "ahk2"
  }
}